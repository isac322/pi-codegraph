{
  "name": "@isac322/pi-codegraph",
  "version": "0.3.1",
  "description": "CodeGraph tools for Pi and OMP with worktree-aware index lifecycle management.",
  "license": "MIT",
  "type": "module",
  "author": "isac322",
  "homepage": "https://github.com/isac322/pi-codegraph#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isac322/pi-codegraph.git"
  },
  "bugs": {
    "url": "https://github.com/isac322/pi-codegraph/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "omp",
    "codegraph",
    "mcp",
    "worktree",
    "coding-agent"
  ],
  "files": [
    ".mcp.json",
    "dist",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "bin": {
    "pi-codegraph-mcp": "./dist/bin/codegraph-mcp.js"
  },
  "pi": {
    "extensions": [
      "./dist/extensions/pi.js"
    ]
  },
  "omp": {
    "extensions": [
      "./dist/extensions/omp.js"
    ]
  },
  "engines": {
    "node": ">=22.19.0 <25.0.0"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json && node scripts/ensure-bin-executable.ts",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test:omp:docker": "docker build --file tests/docker/Dockerfile.omp --tag pi-codegraph-omp-integration . && docker run --rm pi-codegraph-omp-integration",
    "test": "npm run build && node --test tests/codegraph.test.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test:integration:daemon": "docker build -f tests/docker/Dockerfile.omp -t pi-codegraph-omp-integration . && docker run --rm --init pi-codegraph-omp-integration bun tests/shared-daemon-docker.integration.ts",
    "test:integration:pi": "docker build -f tests/docker/Dockerfile.pi -t pi-codegraph-pi-integration . && docker run --rm --init pi-codegraph-pi-integration"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@colbymchenry/codegraph": "1.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@earendil-works/pi-tui": "^0.80.10",
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
